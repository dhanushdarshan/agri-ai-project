let currentLang = localStorage.getItem('agroLang') || 'en';

function applyTranslations() {
  const t = translations[currentLang];
  document.querySelectorAll('[data-key]').forEach(el => { if(t[el.getAttribute('data-key')]) el.innerText = t[el.getAttribute('data-key')]; });
  document.querySelectorAll('.tb-title, .sec-title, .nav-item span').forEach(el => { if(el.getAttribute('data-key')) return; const key = el.innerText.trim(); if(t[key]) el.innerText = t[key]; });
}
function setLang(lang) { currentLang = lang; localStorage.setItem('agroLang', lang); document.querySelectorAll('.lang-btn').forEach(btn => btn.classList.remove('on')); document.querySelector(`.lang-btn[data-lang="${lang}"]`).classList.add('on'); applyTranslations(); }

function goPage(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  if (id === 'pg-dash') { updateFarmerUI(); buildHomeCharts(); updateDynamicContent(); }
}
function validateAndEnterDashboard() {
  const name = document.getElementById('inp-name').value.trim();
  const district = document.getElementById('inp-district').value;
  if (!name) { alert(translations[currentLang]['Please enter your name'] || "Please enter your name"); return; }
  if (!district) { alert(translations[currentLang]['Please select a district'] || "Please select a district"); return; }
  farmer.name = name;
  farmer.crop = document.getElementById('inp-crop').value;
  farmer.acres = document.getElementById('inp-acres').value;
  farmer.district = district;
  farmer.soil = document.getElementById('inp-soil').value;
  goPage('pg-dash');
}
function updateFarmerUI() {
  const words = farmer.name.trim().split(/\s+/);
  const initials = words.map(w => w.charAt(0)).join('').toUpperCase().slice(0,2);
  ['sb-av','tb-av'].forEach(id => { const el = document.getElementById(id); if(el) el.textContent = initials; });
  ['sb-name','tb-name','hero-name'].forEach(id => { const el = document.getElementById(id); if(el) el.textContent = farmer.name; });
  const sbCrop = document.getElementById('sb-crop');
  if(sbCrop) sbCrop.textContent = farmer.crop + ' · ' + farmer.acres + ' acres';
  document.getElementById('heroCropStatus').innerHTML = `${farmer.crop} crop · Day 67 of 150`;
  const settingsName = document.getElementById('settingsName'); if(settingsName) settingsName.value = farmer.name;
  const settingsDistrict = document.getElementById('settingsDistrict'); if(settingsDistrict) settingsDistrict.value = farmer.district;
  const settingsCrop = document.getElementById('settingsCrop'); if(settingsCrop) settingsCrop.value = farmer.crop;
}
function updateDynamicContent() {
  renderAlertsAndActivity();
  renderAlertHistory();
}
