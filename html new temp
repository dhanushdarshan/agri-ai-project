function renderAlertHistory() {
  const container = document.getElementById('alertHistoryContainer');
  if(!container) return;
  let html = `<div class="tl-item"><div class="tl-dot r"></div><div class="tl-card"><div class="tl-date">Today, 8:14 AM</div><div class="tl-title">⚠ Late Blight Risk Detected</div><div class="tl-desc">High humidity 72% + cool nights = ideal for late blight. Apply Mancozeb 75 WP within 48 hrs.</div><button class="btn btn-p btn-sm" style="margin-top:.6rem" onclick="showSection('disease',null)">View Treatment →</button></div></div>`;
