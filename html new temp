    html += `<div class="tl-item"><div class="tl-dot r"></div><div class="tl-card"><div class="tl-date">${lastDisease.timestamp}</div><div class="tl-title">⚠ ${lastDisease.name} Detected</div><div class="tl-desc">Detected in ${lastDisease.district}. Apply recommended treatment immediately.</div></div></div>`;
