function t(key) { return (T[appLang] && T[appLang][key]) || (T['en'][key]) || key; }

function applyTranslations() {
  document.querySelectorAll('[data-i18n]').forEach(el => {
    const key = el.getAttribute('data-i18n');
    const val = t(key);
    if (el.tagName === 'INPUT' && el.type !== 'hidden') { /* skip */ }
    else { el.textContent = val; }
  });
  const tb = document.getElementById('tb-title');
  if (tb) {
    const currentSection = document.querySelector('.dash-section.on');
    if (currentSection) {
      const id = currentSection.id.replace('sec-', '');
      tb.textContent = t(sectionTitles[id] || id);
    }
  }
}

function setAppLang(lang, btn) {
  appLang = lang;
  localStorage.setItem('agro_lang', lang);
  document.querySelectorAll('.lang-btn').forEach(b => b.classList.remove('on'));
  document.querySelectorAll('.lang-btn-settings').forEach(b => { b.classList.remove('btn-p'); b.classList.add('btn-o'); });
  if (btn) {
    btn.classList.remove('btn-o'); btn.classList.add('btn-p');
    const label = btn.textContent.slice(0,2);
    document.querySelectorAll('.lang-btn').forEach(b => { if (b.textContent.trim() === label) b.classList.add('on'); });
  }
  applyTranslations();
}

function goPage(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  const target = document.getElementById(id);
  if (target) target.classList.add('active');
  if (id === 'pg-dash') { updateFarmerUI(); buildHomeCharts(); }
  applyTranslations();
}

function enterDashboard() {
  const nEl = document.getElementById('inp-name');
  const cEl = document.getElementById('inp-crop');
  const aEl = document.getElementById('inp-acres');
  const dEl = document.getElementById('inp-district');
  const name = nEl ? nEl.value.trim() : '';
  const crop = cEl ? cEl.value.trim() : '';
  const district = dEl ? dEl.value.trim() : '';
  if (!name)     { alert(t('val-name'));     nEl.focus(); return; }
  if (!crop)     { alert(t('val-crop'));     cEl.focus(); return; }
  if (!district) { alert(t('val-district')); dEl.focus(); return; }
  farmer.name = name; farmer.crop = crop;
  farmer.acres = aEl ? aEl.value.trim() || '5' : '5';
  farmer.district = district;
  const sn = document.getElementById('settings-name');
  const sd = document.getElementById('settings-district');
  const sc = document.getElementById('settings-crop');
  if (sn) sn.value = farmer.name;
  if (sd) sd.value = farmer.district;
  if (sc) { for (let o of sc.options) { if (o.value === farmer.crop) { o.selected = true; break; } } }
  goPage('pg-dash');
}

function updateFarmerUI() {
  const words = farmer.name.trim().split(/\s+/);
  const initials = words.map(w => w.charAt(0)).join('').toUpperCase().slice(0,2);
  const els = {'sb-av':initials,'tb-av':initials,'sb-name':farmer.name,'tb-name':farmer.name,'hero-name':farmer.name};
  Object.keys(els).forEach(id => { const el = document.getElementById(id); if (el) el.textContent = els[id]; });
  const sbCrop = document.getElementById('sb-crop');
  if (sbCrop) sbCrop.textContent = farmer.crop + ' · ' + farmer.acres + ' acres';
}

const sectionTitles = { home:'Farm Overview', crops:'Crop Advice', disease:'Disease Check', alerts:'Alerts', settings:'Settings' };

function showSection(name, navEl) {
  document.querySelectorAll('.dash-section').forEach(s => s.classList.remove('on'));
  const sec = document.getElementById('sec-' + name);
  if (sec) sec.classList.add('on');
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('on'));
  if (navEl) { navEl.classList.add('on'); } else {
    const order = ['home','crops','disease','alerts','settings'];
    const idx = order.indexOf(name);
    const items = document.querySelectorAll('.nav-item');
    if (items[idx]) items[idx].classList.add('on');
  }
  const tb = document.getElementById('tb-title');
  if (tb) tb.textContent = t(sectionTitles[name] || name);
  if (name === 'crops') initCropRecommendation();
  if (name === 'disease' && typeof tfLoadModel === 'function') tfLoadModel();
  applyTranslations();
}

