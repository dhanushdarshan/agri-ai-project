/* ================================================================
   UPDATED handleOTP — DEMO MODE (any OTP works)
   ================================================================ */
function handleOTP() {
  const input    = document.getElementById('userInput');
  const otpBox   = document.getElementById('otpSection');
  const btn      = document.getElementById('otpBtn');

  /* STEP 1: Show OTP field */
  if (!otpSent) {
    if (!input.value.trim()) {
      alert('Please enter email or phone');
      input.focus();
      return;
    }
    /* Show OTP section */
    otpBox.style.display = 'block';
    btn.textContent = 'Verify & Login';
    otpSent = true;
    /* Focus OTP field for smooth UX */
    const otpInput = document.getElementById('otpInput');
    if (otpInput) setTimeout(() => otpInput.focus(), 100);
    return;
  }

  /* STEP 2: Accept any OTP — show loading then redirect */
  btn.textContent = 'Verifying...';
  btn.disabled = true;

  setTimeout(function () {
    btn.disabled = false;
    btn.textContent = 'Verify & Login';
    /* Reset state for next login */
    otpSent = false;
    otpBox.style.display = 'none';
    document.getElementById('otpInput').value = '';
    input.value = '';
    goPage('pg-setup');
  }, 1000);
}

