  let currentWeather = { temp: 28, condition: 'Sunny', humidity: 65, wind: 12, icon: '☀️' };
  function updateWeatherForDistrict(district) {
    const weatherTypes = [{ cond: 'Sunny', icon: '☀️', tempRange: [26,34], humid: [40,60] }, { cond: 'Partly Cloudy', icon: '⛅', tempRange: [24,30], humid: [55,70] }, { cond: 'Cloudy', icon: '☁️', tempRange: [22,28], humid: [65,80] }, { cond: 'Light Rain', icon: '🌧️', tempRange: [20,26], humid: [80,95] }];
    const idx = Math.floor(Math.random() * weatherTypes.length);
    const wt = weatherTypes[idx];
    currentWeather.temp = Math.floor(Math.random() * (wt.tempRange[1] - wt.tempRange[0] + 1) + wt.tempRange[0]);
    currentWeather.condition = wt.cond;
    currentWeather.icon = wt.icon;
    currentWeather.humidity = Math.floor(Math.random() * (wt.humid[1] - wt.humid[0] + 1) + wt.humid[0]);
    currentWeather.wind = Math.floor(Math.random() * 20) + 5;
    document.getElementById('weatherIcon').innerHTML = currentWeather.icon;
    document.getElementById('weatherTemp').innerHTML = `${currentWeather.temp}°C`;
    document.getElementById('weatherCondition').innerHTML = currentWeather.condition;
    document.getElementById('weatherHumidity').innerHTML = `${currentWeather.humidity}%`;
    document.getElementById('weatherWind').innerHTML = `${currentWeather.wind} km/h`;
    let advice = "";
    if(currentWeather.condition.includes('Rain')) advice = "🌧️ Avoid spraying pesticides today. Good for transplanted crops.";
    else if(currentWeather.temp > 32) advice = "🔥 High temperature! Provide shade nets for vegetables.";
    else if(currentWeather.condition === 'Sunny') advice = "☀️ Ideal for harvesting and drying grains.";
    else advice = "🌱 Favorable conditions for sowing and weeding.";
    document.getElementById('weatherAdvice').innerHTML = advice;
  }

  const marketPrices = {};
  KARNATAKA_DISTRICTS.forEach(district => { marketPrices[district] = { mandi: `${district} APMC`, crops: { 'Tomato': 2300+Math.floor(Math.random()*600), 'Onion': 1900+Math.floor(Math.random()*500), 'Ragi': 2700+Math.floor(Math.random()*400), 'Rice': 2100+Math.floor(Math.random()*500), 'Groundnut': 5600+Math.floor(Math.random()*600), 'Banana': 4200+Math.floor(Math.random()*600) } }; });
  let currentDistrict = 'Bengaluru Urban';
  let priceChart, profitChart;

  function populateDistricts() { const sel = document.getElementById('districtSelect'); KARNATAKA_DISTRICTS.forEach(d => { sel.innerHTML += `<option value="${d}">${d}</option>`; }); }
  
  function showCropDetails(crop) {
    const c = CROP_DB[crop]; if(!c) return;
    const roi = ((c.profitPerAcre / c.investmentPerAcre)*100).toFixed(0);
    document.getElementById('modalTitle').innerHTML = `${c.emoji} ${crop} - Complete Growing Guide`;
    document.getElementById('modalContent').innerHTML = `
      <div class="info-grid">
        <div class="info-item"><div class="info-label">🥗 Nutrition & Benefits</div><div class="info-value">${c.nutrition}</div></div>
        <div class="info-item"><div class="info-label">🌱 Soil Requirement</div><div class="info-value">${c.soil}</div></div>
        <div class="info-item"><div class="info-label">🌡️ Temperature</div><div class="info-value">${c.temp}</div></div>
        <div class="info-item"><div class="info-label">💧 Water Need</div><div class="info-value">${c.water}</div></div>
        <div class="info-item"><div class="info-label">⏳ Duration</div><div class="info-value">${c.duration}</div></div>
        <div class="info-item"><div class="info-label">💰 Investment/Acre</div><div class="info-value">₹${c.investmentPerAcre.toLocaleString()}</div></div>
        <div class="info-item"><div class="info-label">📈 Net Profit/Acre</div><div class="info-value">₹${c.profitPerAcre.toLocaleString()}</div></div>
        <div class="info-item"><div class="info-label">📊 ROI</div><div class="info-value" style="color:#2d6a4f;">${roi}%</div></div>
        <div class="info-item"><div class="info-label">🌾 Fertilizer Schedule</div><div class="info-value">${c.fertilizer}</div></div>
        <div class="info-item"><div class="info-label">🐛 Pest & Disease Control</div><div class="info-value">${c.pestControl}</div></div>
        <div class="info-item"><div class="info-label">✂️ Harvesting Tips</div><div class="info-value">${c.harvestTip}</div></div>
        <div class="info-item"><div class="info-label">📅 Best Season</div><div class="info-value">${c.season}</div></div>
      </div>
      <div class="farming-tip">💡 <strong>Smart Farming Tip:</strong> ${currentWeather.condition === 'Sunny' ? 'Apply mulch to retain soil moisture.' : (currentWeather.condition.includes('Rain') ? 'Avoid overwatering; check drainage.' : 'Ideal for foliar nutrient spray.')}</div>
    `;
    document.getElementById('cropModal').style.display = 'flex';
  }
  function closeModal() { document.getElementById('cropModal').style.display = 'none'; }

  function loadDashboard() {
    const district = document.getElementById('districtSelect').value;
    if (!district || !marketPrices[district]) { alert('Please select a district from 31 Karnataka districts'); return; }
    currentDistrict = district;
    document.getElementById('headerLocation').innerHTML = district;
    updateWeatherForDistrict(district);
    document.getElementById('loadingIndicator').classList.remove('hidden');
    document.getElementById('dashboard').classList.add('hidden');
    setTimeout(() => { renderDashboard(district); document.getElementById('loadingIndicator').classList.add('hidden'); document.getElementById('dashboard').classList.remove('hidden'); }, 300);
  }

  function renderDashboard(district) {
    document.getElementById('statsGrid').innerHTML = `<div class="stat-card"><div>🌾</div><strong>${allCrops.length}+ Crops</strong><br>with complete guides</div><div class="stat-card"><div>📍</div><strong>${district}</strong><br>Your District</div><div class="stat-card"><div>💰</div><strong>Avg ROI: 68%</strong><br>Realistic Returns</div><div class="stat-card"><div>🏪</div><strong>${marketPrices[district]?.mandi}</strong><br>Local Mandi</div>`;
    
    document.getElementById('recsTab').innerHTML = `<div class="crops-grid">${allCrops.map(crop => {
      const c = CROP_DB[crop];
      const roi = ((c.profitPerAcre / c.investmentPerAcre)*100).toFixed(0);
      return `<div class="crop-card" onclick="showCropDetails('${crop}')">
        <div class="crop-header"><span class="crop-emoji">${c.emoji}</span><span class="crop-name">${crop}<span class="demand-badge demand-${c.demand === 'Very High' ? 'veryhigh' : 'high'}">${c.demand}</span></span></div>
        <div class="crop-details-row"><span class="crop-detail-item">🌡️ ${c.temp}</span><span class="crop-detail-item">💧 ${c.water}</span><span class="crop-detail-item">⏳ ${c.duration}</span></div>
        <div class="crop-profit">💰 Investment: ₹${c.investmentPerAcre.toLocaleString()}/acre | Net Profit: ₹${c.profitPerAcre.toLocaleString()}</div>
        <div class="extra-info">🌱 Fertilizer: ${c.fertilizer?.substring(0, 55)}... 🐛 Pest: ${c.pestControl?.substring(0, 45)}</div>
        <div style="font-size:0.7rem; margin-top:6px; color:#e76f51;">📊 ROI: ${roi}% | 🔍 Click for full guide</div>
      </div>`}).join('')}</div>`;
    
    const cropsMarket = marketPrices[district]?.crops; const entries = Object.entries(cropsMarket);
    document.getElementById('mandiName').innerHTML = marketPrices[district]?.mandi;
    document.getElementById('marketTableBody').innerHTML = entries.map(([crop, price]) => `<tr onclick="showCropDetails('${crop}')" style="cursor:pointer"><tr><strong>${crop}</strong><td class="price-positive">₹${price.toLocaleString()}<td><span class="demand-badge demand-high">High</span><td style="color:green">▲ +${Math.floor(Math.random() * 6) + 2}%</tr>`).join('');
    if(priceChart) priceChart.destroy(); 
    priceChart = new Chart(document.getElementById('priceChart'), { type: 'bar', data: { labels: entries.slice(0,6).map(e=>e[0]), datasets: [{ label: 'Price (₹/quintal)', data: entries.slice(0,6).map(e=>e[1]), backgroundColor: '#52b788', borderRadius: 8 }] }, options: { responsive: true, maintainAspectRatio: false } });
    
    const calcSelect = document.getElementById('calcCrop'); calcSelect.innerHTML = ''; allCrops.forEach(c => calcSelect.innerHTML += `<option value="${c}">${c}</option>`);
    document.getElementById('alertsArea').innerHTML = `<div class="stat-card" style="border-left:4px solid #f4a261;">✅ <strong>${district}</strong> — Live weather: ${currentWeather.condition}, ${currentWeather.temp}°C. Click any crop for fertilizer, pest control & harvest guide.</div>`;
    calculateProfit();
  }

  function calculateProfit() {
    const crop = document.getElementById('calcCrop').value;
    const acres = parseFloat(document.getElementById('calcAcres').value) || 1;
    const c = CROP_DB[crop];
    if(!c) return;
    const investment = c.investmentPerAcre * acres;
    const netProfit = c.profitPerAcre * acres;
    const roi = (c.profitPerAcre / c.investmentPerAcre) * 100;
    const grossRevenue = investment + netProfit;
    document.getElementById('profitResult').innerHTML = `
      <div class="stats-grid" style="grid-template-columns:repeat(auto-fit,minmax(180px,1fr)); margin-bottom:0;">
        <div class="stat-card investment-card"><div class="info-label">💰 TOTAL INVESTMENT</div><div class="info-value" style="font-size:1.3rem;">₹${investment.toLocaleString()}</div><small>Seeds, labor, fertilizers, irrigation</small></div>
        <div class="stat-card"><div class="info-label">📈 GROSS REVENUE</div><div class="info-value" style="font-size:1.3rem;">₹${grossRevenue.toLocaleString()}</div><small>Expected market sales</small></div>
        <div class="stat-card"><div class="info-label">✅ NET PROFIT</div><div class="info-value" style="font-size:1.3rem; color:#2d6a4f;">₹${netProfit.toLocaleString()}</div><small>Profit after expenses</small></div>
        <div class="stat-card"><div class="info-label">📊 RETURN ON INVESTMENT (ROI)</div><div class="info-value roi-positive" style="font-size:1.3rem;">${roi.toFixed(1)}%</div><small>${roi>50?'Excellent profitability':'Moderate'}</small></div>
      </div>
      <div class="profit-highlight">🌾 ${c.emoji} ${crop} | Season: ${c.season} | Water: ${c.water} | Current weather: ${currentWeather.condition} ${currentWeather.temp}°C - ${currentWeather.condition.includes('Rain')?'Delay fertilizer application':'Good for field preparation'}</div>
    `;
    if(profitChart) profitChart.destroy();
    profitChart = new Chart(document.getElementById('profitChart'), { type: 'bar', data: { labels: ['Investment per Acre', 'Net Profit per Acre'], datasets: [{ label: 'Amount (₹)', data: [c.investmentPerAcre, c.profitPerAcre], backgroundColor: ['#f4a261', '#2d6a4f'], borderRadius: 8 }] }, options: { responsive: true, maintainAspectRatio: false, plugins: { tooltip: { callbacks: { label: (ctx) => `₹${ctx.raw.toLocaleString()}` } } } } });
  }

  function detectLocation() {
    if (!navigator.geolocation) { alert('❌ Geolocation not supported.'); return; }
    document.getElementById('loadingIndicator').classList.remove('hidden');
    navigator.geolocation.getCurrentPosition((position) => {
      const lat = position.coords.latitude, lon = position.coords.longitude;
      let closestDistrict = 'Bengaluru Urban'; let minDistance = Infinity;
      for (const [district, coords] of Object.entries(DISTRICT_COORDINATES)) { const distance = Math.hypot(lat - coords.lat, lon - coords.lon); if (distance < minDistance) { minDistance = distance; closestDistrict = district; } }
      document.getElementById('districtSelect').value = closestDistrict; document.getElementById('headerLocation').innerHTML = closestDistrict;
      document.getElementById('locationBadge').classList.add('gps-success'); setTimeout(() => document.getElementById('locationBadge').classList.remove('gps-success'), 500);
      const toast = document.createElement('div'); toast.className = 'location-toast'; toast.innerHTML = `📍 GPS: ${closestDistrict}<br>Lat: ${lat.toFixed(2)}`; document.body.appendChild(toast); setTimeout(() => toast.remove(), 4000);
      document.getElementById('loadingIndicator').classList.add('hidden'); loadDashboard();
    }, () => { document.getElementById('loadingIndicator').classList.add('hidden'); alert('Location permission denied.'); }, { enableHighAccuracy: true, timeout: 10000 });
  }

  function initTabs() { document.querySelectorAll('.tab').forEach(btn => { btn.addEventListener('click', () => { const tabId = btn.getAttribute('data-tab'); document.querySelectorAll('.tab-pane').forEach(p => p.classList.add('hidden')); document.getElementById(`${tabId}Tab`).classList.remove('hidden'); document.querySelectorAll('.tab').forEach(b => b.classList.remove('active')); btn.classList.add('active'); }); }); }
  window.onload = () => { populateDistricts(); initTabs(); document.getElementById('loadBtn').onclick = loadDashboard; document.getElementById('gpsBtn').onclick = detectLocation; document.getElementById('calcBtn').onclick = calculateProfit; document.getElementById('calcAcres').oninput = calculateProfit; setTimeout(() => { if (confirm('🌾 Welcome to AgriAI! Use GPS to detect your district for live weather & crop insights?')) detectLocation(); }, 500); };
</script>
</body>
</html>
