    'Turmeric': { emoji: '🟡', nutrition: { calories: 310, protein: 8, carbs: 65, fiber: 21, vitamins: 'B6, C, Iron', benefits: 'Anti-inflammatory, immunity' }, soil: { type: 'Well-drained loamy', ph: '5.5-7.0', organic: 'High' }, temperature: { min: 20, max: 38, optimal: '25-30°C', rainfall: '1000-1500 mm' }, growingRegions: 'Telangana, Maharashtra, Karnataka, TN', demand: 'Very High', farmers: '1.2M+', priceRange: '₹8,000-12,000', season: 'Kharif', water: 'High' },
    'Ginger': { emoji: '🫚', nutrition: { calories: 80, protein: 1.8, carbs: 18, fiber: 2, vitamins: 'B6, C, Magnesium', benefits: 'Digestion, anti-nausea' }, soil: { type: 'Well-drained loamy', ph: '5.5-6.5', organic: 'High' }, temperature: { min: 19, max: 35, optimal: '22-28°C', rainfall: '1500-2000 mm' }, growingRegions: 'Karnataka, Kerala, NE states', demand: 'High', farmers: '800K+', priceRange: '₹7,000-12,000', season: 'Kharif', water: 'High' }
  };
  const allCrops = Object.keys(CROP_DB);
  
  // 25+ Karnataka districts market data
  const marketData = {
    'Bangalore Urban': { mandi: 'Yeshwanthpur APMC', crops: { Tomato: 2850, Onion: 1820, Potato: 1550, Ragi: 2150, Rice: 3250, Groundnut: 5850, Banana: 2800, Coconut: 1900 } },
    'Mysore': { mandi: 'Mysore APMC', crops: { Tomato: 2650, Onion: 1750, Sugarcane: 3550, Ragi: 2080, Rice: 3150, Groundnut: 5750 } },
    'Dharwad': { mandi: 'Dharwad APMC', crops: { Groundnut: 5950, Cotton: 6600, Onion: 1780, Sunflower: 5550, Maize: 1750 } },
    'Hubli': { mandi: 'Hubli APMC', crops: { Cotton: 6700, Groundnut: 5900, Chickpea: 5150, Wheat: 2280, Maize: 1730 } },
    'Belgaum': { mandi: 'Belgaum APMC', crops: { Sugarcane: 3750, Cotton: 6450, Onion: 1880, Tomato: 2350, Soybean: 4400 } },
    'Mandya': { mandi: 'Mandya APMC', crops: { Sugarcane: 3650, Rice: 3350, Ragi: 2020, Banana: 2850, Coconut: 1850 } },
    'Tumkur': { mandi: 'Tumkur APMC', crops: { Coconut: 1950, Groundnut: 5950, Ragi: 2130, Tomato: 2750, Banana: 2700 } },
    'Hassan': { mandi: 'Hassan APMC', crops: { Coffee: 35500, Arecanut: 40500, Rice: 3250, Ginger: 7300, Potato: 1500 } },
    'Shimoga': { mandi: 'Shimoga APMC', crops: { Arecanut: 42500, Paddy: 2850, Banana: 2650, Coconut: 1950, Ginger: 7500 } },
    'Kolar': { mandi: 'Kolar APMC', crops: { Tomato: 2950, Potato: 1650, Ragi: 2180, Onion: 1800, Carrot: 2450 } },
    'Raichur': { mandi: 'Raichur APMC', crops: { Rice: 3150, Cotton: 6250, Sunflower: 5450, Groundnut: 5700, Maize: 1700 } }
  };
  const districtList = Object.keys(marketData);
  
  let currentDistrict = 'Bangalore Urban';
  let priceChart, profitChart;
  
  function populateDistricts() { const sel = document.getElementById('districtSelect'); districtList.forEach(d => sel.innerHTML += `<option value="${d}">${d}</option>`); }
  function getCropEmoji(crop) { return CROP_DB[crop]?.emoji || '🌾'; }
  function showCropDetails(crop) { const c = CROP_DB[crop]; if(!c) return; document.getElementById('modalTitle').innerHTML = `${c.emoji} ${crop} - Complete Guide`; document.getElementById('modalContent').innerHTML = `<div class="info-section"><h4>🥗 Nutrition (per 100g)</h4><div class="info-grid"><div class="info-item"><div class="info-label">Calories</div><div class="info-value">${c.nutrition.calories}</div></div><div class="info-item"><div class="info-label">Protein</div><div class="info-value">${c.nutrition.protein}g</div></div><div class="info-item"><div class="info-label">Carbs</div><div class="info-value">${c.nutrition.carbs}g</div></div><div class="info-item"><div class="info-label">Fiber</div><div class="info-value">${c.nutrition.fiber}g</div></div><div class="info-item"><div class="info-label">Vitamins</div><div class="info-value">${c.nutrition.vitamins}</div></div><div class="info-item"><div class="info-label">Benefits</div><div class="info-value">${c.nutrition.benefits}</div></div></div></div><div class="info-section"><h4>🌱 Growing Requirements</h4><div class="info-grid"><div class="info-item"><div class="info-label">Soil</div><div class="info-value">${c.soil.type} (pH ${c.soil.ph})</div></div><div class="info-item"><div class="info-label">Temperature</div><div class="info-value">${c.temperature.min}°C - ${c.temperature.max}°C</div></div><div class="info-item"><div class="info-label">Rainfall</div><div class="info-value">${c.temperature.rainfall}</div></div><div class="info-item"><div class="info-label">Water Need</div><div class="info-value">${c.water}</div></div></div></div><div class="info-section"><h4>📍 Market & Regions</h4><div class="info-grid"><div class="info-item"><div class="info-label">Growing Regions</div><div class="info-value">${c.growingRegions}</div></div><div class="info-item"><div class="info-label">Demand</div><div class="info-value">${c.demand}</div></div><div class="info-item"><div class="info-label">Farmers</div><div class="info-value">${c.farmers}</div></div><div class="info-item"><div class="info-label">Price Range</div><div class="info-value">${c.priceRange}</div></div><div class="info-item"><div class="info-label">Season</div><div class="info-value">${c.season}</div></div></div></div>`; document.getElementById('cropModal').style.display = 'flex'; }
  function closeModal() { document.getElementById('cropModal').style.display = 'none'; }
  
  function loadDashboard(district) { if(!district || !marketData[district]) { alert('Please select a district'); return; } currentDistrict = district; document.getElementById('headerLocation').innerHTML = district; document.getElementById('loadingIndicator').classList.remove('hidden'); document.getElementById('dashboard').classList.add('hidden'); setTimeout(() => { renderFullDashboard(district); document.getElementById('loadingIndicator').classList.add('hidden'); document.getElementById('dashboard').classList.remove('hidden'); }, 400); }
  
  function renderFullDashboard(district) {
    const cropsList = allCrops.slice(0, 30);
    document.getElementById('statsGrid').innerHTML = `<div class="stat-card"><div style="font-size:2rem;">🌤️</div><strong>28°C</strong><br>Kharif Season</div><div class="stat-card"><div style="font-size:2rem;">💰</div><strong>${cropsList.length}+ Crops</strong><br>Available</div><div class="stat-card"><div style="font-size:2rem;">📈</div><strong>${Object.keys(marketData[district].crops).length}</strong><br>Local Crops</div><div class="stat-card"><div style="font-size:2rem;">🏪</div><strong>${marketData[district].mandi}</strong><br>APMC Market</div>`;
    document.getElementById('recsTab').innerHTML = `<div class="crops-grid">${cropsList.map(crop => `<div class="crop-card" onclick="showCropDetails('${crop}')"><div class="crop-emoji">${getCropEmoji(crop)}</div><div class="crop-info"><div class="crop-name">${crop}<span class="demand-badge demand-high">${CROP_DB[crop]?.demand || 'High'}</span></div><div class="progress-bar"><div class="progress-fill" style="width:${CROP_DB[crop]?.demand === 'Very High' ? 90 : 75}%"></div></div><div>🌡️ ${CROP_DB[crop]?.temperature.optimal} | 💧 ${CROP_DB[crop]?.water}</div><div style="font-size:0.7rem; color:#2d6a4f; margin-top:5px;">🔍 Click for full nutrition, soil & market data</div></div></div>`).join('')}</div>`;
    const marketCrops = marketData[district].crops; const entries = Object.entries(marketCrops);
    document.getElementById('mandiName').innerHTML = marketData[district].mandi;
    document.getElementById('marketTableBody').innerHTML = entries.map(([crop, price]) => `<tr onclick="showCropDetails('${crop}')" style="cursor:pointer"><td><strong>${crop}</strong><td class="price-positive">₹${price.toLocaleString()}<td><span class="demand-badge demand-high">High</span><td style="color:green">▲ +${Math.floor(Math.random()*8)+2}%</tr>`).join('');
    if(priceChart) priceChart.destroy(); priceChart = new Chart(document.getElementById('priceChart'), { type: 'bar', data: { labels: entries.slice(0,6).map(e=>e[0]), datasets: [{ label: 'Price (₹/q)', data: entries.slice(0,6).map(e=>e[1]), backgroundColor: '#52b788', borderRadius: 8 }] }, options: { responsive: true, maintainAspectRatio: false } });
    const calcSelect = document.getElementById('calcCrop'); calcSelect.innerHTML = ''; allCrops.forEach(c => calcSelect.innerHTML += `<option value="${c}">${c}</option>`);
    document.getElementById('alertsArea').innerHTML = `<div class="stat-card" style="border-left:4px solid #f4a261;">✅ <strong>${district} | ${Object.keys(marketData[district].crops).length}+ crops in local mandi</strong> — Click any crop card for complete nutrition, soil, temperature & market demand!</div>`;
    calculateProfit();
  }
  
  function calculateProfit() { const crop = document.getElementById('calcCrop').value; const acres = parseFloat(document.getElementById('calcAcres').value) || 1; const basePrice = 2500; const cost = 20000 * acres; const revenue = basePrice * 15 * acres; const profit = revenue - cost; const roi = ((profit/cost)*100).toFixed(1); document.getElementById('profitResult').innerHTML = `<div class="stat-card">💰 Cost: ₹${cost.toLocaleString()}</div><div class="stat-card">📈 Revenue: ₹${revenue.toLocaleString()}</div><div class="stat-card">✅ Profit: ₹${profit.toLocaleString()}</div><div class="stat-card">⚡ ROI: ${roi}%</div>`; if(profitChart) profitChart.destroy(); profitChart = new Chart(document.getElementById('profitChart'), { type: 'bar', data: { labels: ['Cost', 'Revenue', 'Profit'], datasets: [{ label: 'Amount (₹)', data: [cost, revenue, profit], backgroundColor: ['#e76f51', '#52b788', '#f4a261'] }] }, options: { responsive: true, maintainAspectRatio: false } }); }
  
  function detectLocation() { if(!navigator.geolocation) { alert('GPS not supported. Please select district manually.'); return; } document.getElementById('loadingIndicator').classList.remove('hidden'); document.getElementById('headerLocation').innerHTML = 'Locating...'; navigator.geolocation.getCurrentPosition((pos) => { const lat = pos.coords.latitude, lon = pos.coords.longitude; const centers = { 'Bangalore Urban':12.9716, 'Mysore':12.2958, 'Hubli':15.3647, 'Belgaum':15.8497, 'Dharwad':15.4589, 'Mandya':12.5731, 'Tumkur':13.3379, 'Hassan':13.006, 'Shimoga':13.9299, 'Kolar':13.137 }; let closest = 'Bangalore Urban', minDist = Infinity; for(const [d, clat] of Object.entries(centers)) { const dist = Math.abs(lat - clat); if(dist < minDist) { minDist = dist; closest = d; } } document.getElementById('districtSelect').value = closest; document.getElementById('headerLocation').innerHTML = closest; document.getElementById('locationBadge').style.animation = 'gpsPulse 0.5s'; setTimeout(()=> document.getElementById('locationBadge').style.animation = '', 500); loadDashboard(closest); document.getElementById('loadingIndicator').classList.add('hidden'); alert(`📍 Location detected!\nDistrict: ${closest}\nLat: ${lat.toFixed(2)}, Lon: ${lon.toFixed(2)}`); }, (err) => { document.getElementById('loadingIndicator').classList.add('hidden'); alert('⚠️ Location access denied or failed. Please select district manually from dropdown.'); document.getElementById('headerLocation').innerHTML = 'Select District'; }); }
  
  function initTabs() { document.querySelectorAll('.tab').forEach(btn => { btn.addEventListener('click', () => { const tabId = btn.getAttribute('data-tab'); document.querySelectorAll('.tab-pane').forEach(p => p.classList.add('hidden')); document.getElementById(`${tabId}Tab`).classList.remove('hidden'); document.querySelectorAll('.tab').forEach(b => b.classList.remove('active')); btn.classList.add('active'); }); }); }
  
  window.onload = () => { populateDistricts(); initTabs(); document.getElementById('loadBtn').onclick = () => loadDashboard(document.getElementById('districtSelect').value); document.getElementById('gpsBtn').onclick = detectLocation; document.getElementById('calcBtn').onclick = calculateProfit; document.getElementById('calcAcres').oninput = calculateProfit; };
</script>
</body>
