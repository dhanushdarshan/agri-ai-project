    'Turmeric': { emoji: '🟡', nutrition: 'Iron, B6 | 310 cal | Anti-inflammatory, immunity booster', soil: 'Loamy, pH 5.5-7.0', temp: '25-30°C', rainfall: '1000-1500 mm', duration: '7-9 months', regions: 'Telangana, Maharashtra, Karnataka, TN', demand: 'Very High', price: '₹8,000-12,000/q', profitPerAcre: '₹1,50,000-2,50,000', water: 'High', season: 'Kharif' },
    'Ginger': { emoji: '🫚', nutrition: 'Vitamin B6, C, Magnesium | 80 cal | Good for digestion', soil: 'Loamy, pH 5.5-6.5', temp: '22-28°C', rainfall: '1500-2000 mm', duration: '8-9 months', regions: 'Karnataka, Kerala, NE states', demand: 'High', price: '₹7,000-12,000/q', profitPerAcre: '₹1,20,000-2,00,000', water: 'High', season: 'Kharif' },
    'Coffee': { emoji: '☕', nutrition: 'Antioxidants | Low calorie | Boosts alertness', soil: 'Volcanic loam, pH 6.0-6.5', temp: '18-25°C', rainfall: '1500-2000 mm', duration: '3-4 years to bear', regions: 'Karnataka (Coorg), Kerala, TN', demand: 'Very High', price: '₹35,000-45,000/q', profitPerAcre: '₹2,00,000-3,00,000', water: 'High', season: 'Perennial' }
  };
  const allCrops = Object.keys(CROP_DB);

  // Market prices for each district
  const marketPrices = {};
  KARNATAKA_DISTRICTS.forEach(district => {
    marketPrices[district] = {
      mandi: `${district} APMC`,
      crops: {
        'Tomato': Math.floor(Math.random() * 800) + 2600,
        'Onion': Math.floor(Math.random() * 600) + 1600,
        'Ragi': Math.floor(Math.random() * 400) + 2000,
        'Rice': Math.floor(Math.random() * 500) + 3000,
        'Groundnut': Math.floor(Math.random() * 800) + 5400,
        'Banana': Math.floor(Math.random() * 600) + 2400
      }
    };
  });
  marketPrices['Bengaluru Urban'].mandi = 'Yeshwanthpur APMC';
  marketPrices['Mysuru'].mandi = 'Mysore APMC';
  marketPrices['Belagavi'].mandi = 'Belgaum APMC';

  let currentDistrict = 'Bengaluru Urban';
  let priceChart, profitChart;

  function populateDistricts() {
    const sel = document.getElementById('districtSelect');
    KARNATAKA_DISTRICTS.forEach(d => { sel.innerHTML += `<option value="${d}">${d}</option>`; });
  }

  function showCropDetails(crop) {
    const c = CROP_DB[crop];
    if (!c) return;
    document.getElementById('modalTitle').innerHTML = `${c.emoji} ${crop} - Complete Growing Guide`;
    document.getElementById('modalContent').innerHTML = `
      <div class="info-grid">
        <div class="info-item"><div class="info-label">🥗 Nutrition & Benefits</div><div class="info-value">${c.nutrition}</div></div>
        <div class="info-item"><div class="info-label">🌱 Soil Requirement</div><div class="info-value">${c.soil}</div></div>
        <div class="info-item"><div class="info-label">🌡️ Optimal Temperature</div><div class="info-value">${c.temp}</div></div>
        <div class="info-item"><div class="info-label">💧 Rainfall Required</div><div class="info-value">${c.rainfall}</div></div>
        <div class="info-item"><div class="info-label">⏳ Harvest Duration</div><div class="info-value">${c.duration}</div></div>
        <div class="info-item"><div class="info-label">💧 Water Requirement</div><div class="info-value">${c.water}</div></div>
        <div class="info-item"><div class="info-label">🌾 Growing Season</div><div class="info-value">${c.season}</div></div>
        <div class="info-item"><div class="info-label">📍 Major Regions</div><div class="info-value">${c.regions}</div></div>
        <div class="info-item"><div class="info-label">📈 Market Demand</div><div class="info-value">${c.demand}</div></div>
        <div class="info-item"><div class="info-label">💰 Price Range</div><div class="info-value">${c.price}</div></div>
        <div class="info-item"><div class="info-label">📊 Profit/Acre</div><div class="info-value">${c.profitPerAcre}</div></div>
      </div>
    `;
    document.getElementById('cropModal').style.display = 'flex';
  }

  function closeModal() { document.getElementById('cropModal').style.display = 'none'; }

  function loadDashboard() {
    const district = document.getElementById('districtSelect').value;
    if (!district || !marketPrices[district]) { alert('Please select a district from 31 Karnataka districts'); return; }
    currentDistrict = district;
    document.getElementById('headerLocation').innerHTML = district;
    document.getElementById('loadingIndicator').classList.remove('hidden');
    document.getElementById('dashboard').classList.add('hidden');
    setTimeout(() => { renderDashboard(district); document.getElementById('loadingIndicator').classList.add('hidden'); document.getElementById('dashboard').classList.remove('hidden'); }, 400);
  }

  function renderDashboard(district) {
    document.getElementById('statsGrid').innerHTML = `
      <div class="stat-card"><div style="font-size:2rem;">🌾</div><strong>${allCrops.length}+ Crops</strong><br>Available</div>
      <div class="stat-card"><div style="font-size:2rem;">📍</div><strong>${district}</strong><br>Your District</div>
      <div class="stat-card"><div style="font-size:2rem;">📈</div><strong>High Demand</strong><br>Market Active</div>
      <div class="stat-card"><div style="font-size:2rem;">🏪</div><strong>${marketPrices[district]?.mandi}</strong><br>Local Mandi</div>
    `;

    document.getElementById('recsTab').innerHTML = `<div class="crops-grid">${allCrops.map(crop => `
      <div class="crop-card" onclick="showCropDetails('${crop}')">
        <div class="crop-header">
          <span class="crop-emoji">${CROP_DB[crop].emoji}</span>
          <span class="crop-name">${crop}<span class="demand-badge demand-${CROP_DB[crop].demand === 'Very High' ? 'veryhigh' : 'high'}">${CROP_DB[crop].demand}</span></span>
        </div>
        <div class="crop-details-row">
          <span class="crop-detail-item">🌡️ ${CROP_DB[crop].temp}</span>
          <span class="crop-detail-item">💧 ${CROP_DB[crop].water}</span>
          <span class="crop-detail-item">⏳ ${CROP_DB[crop].duration}</span>
        </div>
        <div class="crop-details-row">
          <span class="crop-detail-item">🌱 ${CROP_DB[crop].soil.substring(0, 35)}...</span>
        </div>
        <div class="crop-profit">💰 Profit/Acre: ${CROP_DB[crop].profitPerAcre} | Market: ${CROP_DB[crop].price}</div>
        <div style="font-size:0.65rem; color:#6b8f6e; margin-top:6px;">🔍 Click for complete growing guide</div>
      </div>
    `).join('')}</div>`;

    const cropsMarket = marketPrices[district]?.crops;
    const entries = Object.entries(cropsMarket);
    document.getElementById('mandiName').innerHTML = marketPrices[district]?.mandi;
    document.getElementById('marketTableBody').innerHTML = entries.map(([crop, price]) => `<tr onclick="showCropDetails('${crop}')" style="cursor:pointer"><td><strong>${crop}</strong><td class="price-positive">₹${price.toLocaleString()}<td><span class="demand-badge demand-high">High</span><td style="color:green">▲ +${Math.floor(Math.random() * 8) + 2}%</tr>`).join('');
    
    if (priceChart) priceChart.destroy();
    priceChart = new Chart(document.getElementById('priceChart'), { type: 'bar', data: { labels: entries.slice(0,6).map(e=>e[0]), datasets: [{ label: 'Price (₹/q)', data: entries.slice(0,6).map(e=>e[1]), backgroundColor: '#52b788', borderRadius: 8 }] }, options: { responsive: true, maintainAspectRatio: false } });

    const calcSelect = document.getElementById('calcCrop');
    calcSelect.innerHTML = '';
    allCrops.forEach(c => calcSelect.innerHTML += `<option value="${c}">${c}</option>`);
    document.getElementById('alertsArea').innerHTML = `<div class="stat-card" style="border-left:4px solid #f4a261;">✅ <strong>${district}</strong> — ${allCrops.length}+ crops available. Click any crop card for detailed nutrition, soil, climate & profit information!</div>`;
    calculateProfit();
  }

  function calculateProfit() {
    const crop = document.getElementById('calcCrop').value;
    const acres = parseFloat(document.getElementById('calcAcres').value) || 1;
    const c = CROP_DB[crop];
    const profitPerAcre = parseInt(c?.profitPerAcre?.replace(/[^0-9]/g, '')) || 80000;
    const totalProfit = profitPerAcre * acres;
    document.getElementById('profitResult').innerHTML = `<div class="stat-card">📊 Estimated Profit/Acre: ₹${profitPerAcre.toLocaleString()}</div><div class="stat-card">💰 Total Profit (${acres} acres): ₹${totalProfit.toLocaleString()}</div><div class="stat-card">🌾 Crop: ${crop}</div><div class="stat-card">⭐ Demand: ${c?.demand || 'High'}</div>`;
    if (profitChart) profitChart.destroy();
    profitChart = new Chart(document.getElementById('profitChart'), { type: 'bar', data: { labels: ['Profit per Acre', `Profit for ${acres} Acres`], datasets: [{ label: 'Amount (₹)', data: [profitPerAcre, totalProfit], backgroundColor: ['#52b788', '#2d6a4f'] }] }, options: { responsive: true, maintainAspectRatio: false } });
  }

  // ACCURATE GPS LOCATION DETECTION
  function detectLocation() {
    if (!navigator.geolocation) { alert('❌ Geolocation not supported. Please select district manually.'); return; }
    document.getElementById('loadingIndicator').classList.remove('hidden');
    document.getElementById('headerLocation').innerHTML = 'Detecting...';
    
    navigator.geolocation.getCurrentPosition(
      (position) => {
        const lat = position.coords.latitude;
        const lon = position.coords.longitude;
        
        let closestDistrict = 'Bengaluru Urban';
        let minDistance = Infinity;
        
        for (const [district, coords] of Object.entries(DISTRICT_COORDINATES)) {
          const distance = Math.hypot(lat - coords.lat, lon - coords.lon);
          if (distance < minDistance) { minDistance = distance; closestDistrict = district; }
        }
        
        document.getElementById('districtSelect').value = closestDistrict;
        document.getElementById('headerLocation').innerHTML = closestDistrict;
        document.getElementById('locationBadge').classList.add('gps-success');
        setTimeout(() => document.getElementById('locationBadge').classList.remove('gps-success'), 500);
        
        const toast = document.createElement('div');
        toast.className = 'location-toast';
        toast.innerHTML = `📍 Accurate location detected!<br>District: ${closestDistrict}<br>Lat: ${lat.toFixed(4)}, Lon: ${lon.toFixed(4)}`;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 4000);
        
        document.getElementById('loadingIndicator').classList.add('hidden');
        loadDashboard();
      },
      (error) => {
        document.getElementById('loadingIndicator').classList.add('hidden');
        let msg = '❌ Location detection failed. ';
        if (error.code === 1) msg = '❌ Location permission denied. Please allow location access.';
        alert(msg + ' Please select district manually from dropdown.');
        document.getElementById('headerLocation').innerHTML = 'Select District';
      },
      { enableHighAccuracy: true, timeout: 10000 }
    );
  }

  function initTabs() {
    document.querySelectorAll('.tab').forEach(btn => {
      btn.addEventListener('click', () => {
        const tabId = btn.getAttribute('data-tab');
        document.querySelectorAll('.tab-pane').forEach(p => p.classList.add('hidden'));
        document.getElementById(`${tabId}Tab`).classList.remove('hidden');
        document.querySelectorAll('.tab').forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
      });
    });
  }

  window.onload = () => {
    populateDistricts();
    initTabs();
    document.getElementById('loadBtn').onclick = loadDashboard;
    document.getElementById('gpsBtn').onclick = detectLocation;
    document.getElementById('calcBtn').onclick = calculateProfit;
    document.getElementById('calcAcres').oninput = calculateProfit;
    setTimeout(() => { if (confirm('🌾 Welcome to AgriAI! Would you like to automatically detect your district using GPS?')) detectLocation(); }, 500);
  };
</script>
</body>
</html>
